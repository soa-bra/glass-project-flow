# ============================================================================
# SoaBra — مثال متغيّرات البيئة
# ============================================================================
# انسخ هذا الملف إلى `.env` واملأ القيم حسب بيئتك.
# المتغيّرات المسبوقة بـ VITE_ مكشوفة للمتصفح (آمنة كـ public keys فقط).

# --- Supabase (مولّدة تلقائيًا من Lovable) ----------------------------------
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# --- Feature Flags (P0 — Phase Mock Replacement Strategy) -------------------
# عند true: تستخدم المساحة بياناتها الـ mock الحالية.
# عند false: تقرأ من قاعدة البيانات المركزية (يستخدم في P3 Workspace Integration).
# الافتراضي true حتى تكتمل الخدمات في P1 ويبدأ نقل المساحات في P3.

VITE_USE_MOCK_PROJECTS="true"   # ProjectWorkspace + mockProjects.ts
VITE_USE_MOCK_OPS="true"        # OperationsBoard + mockData.ts
VITE_USE_MOCK_AUDIT="true"      # services/audit.ts (mockAuditEvents)
VITE_USE_MOCK_DEPARTMENTS="true" # DepartmentTabs (عدا Invoices المُفعَّلة فعليًا)

# --- وضع التطوير ------------------------------------------------------------
# يفعّل console logs إضافية ومؤشرات أداء داخل الـ canvas.
VITE_DEV_VERBOSE="false"
